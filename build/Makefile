	$(MAKE) $(MAKESILENT) -f CMakeFiles/ctc_sigma_shared.dir/build.make CMakeFiles/ctc_sigma_shared.dir/src/sponge.c.i
.PHONY : src/sponge.c.i

src/sponge.s: src/sponge.c.s
.PHONY : src/sponge.s

# target to generate assembly for a file
src/sponge.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/ctc_sigma_static.dir/build.make CMakeFiles/ctc_sigma_static.dir/src/sponge.c.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/ctc_sigma_shared.dir/build.make CMakeFiles/ctc_sigma_shared.dir/src/sponge.c.s
.PHONY : src/sponge.c.s

